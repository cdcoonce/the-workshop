{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(make test)",
      "Bash(make docs)",
      "Bash(make build)",
      "Bash(make verify-generated)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 core/hooks/protect-files.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 presets/claude-tooling/hooks/post-edit-lint.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "workbench@claude-workflow": true
  }
}
