{
  "name": "claude-tooling",
  "description": "Developing Claude skills, hooks, agents, and template configurations",
  "conventions": [
    "Skills follow the required SKILL.md structure",
    "Progressive disclosure over monolithic instructions",
    "Regenerate docs and dist after changing a component"
  ],
  "version": "1.0.0",
  "core": {
    "skills": "all",
    "hooks": [
      "protect-files.py",
      "verify-tests-before-stop.py",
      "snapshot-subagent-start.py",
      "verify-subagent-evidence.py",
      "audit-config-change.py"
    ]
  },
  "exclude": [],
  "preset_skills": [],
  "preset_hooks": [
    "post-edit-lint.py"
  ],
  "preset_agents": [
    "skill-builder",
    "skill-reviewer"
  ]
}
